# SMTP Configuration for Consultation Form Email
# Copy this file to .env.local and fill in your actual values

# SMTP Host (e.g., smtp.gmail.com, smtp.sendgrid.net)
SMTP_HOST=smtp.gmail.com

# SMTP Port (e.g., 587 for TLS, 465 for SSL)
SMTP_PORT=587

# Use 'true' for SSL, 'false' for TLS
SMTP_SECURE=false

# Your email address
SMTP_USER=your-email@gmail.com

# Your app password (for Gmail, use App Password, not your regular password)
SMTP_PASS=your-app-password

# Recipient email (where consultation requests will be sent)
# This can also be configured in the API route directly

